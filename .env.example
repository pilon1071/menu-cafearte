# Credenciales de Clover API
# Copia este archivo como .env y completa tus datos

# Tu API Token de Clover (Personal Access Token)
CLOVER_API_TOKEN=ee7ee17b-e487-a2da-f23e-692531ebe680

# Tu Merchant ID de Clover
CLOVER_MERCHANT_ID=RBRAKZRYB47E1

# Región de Clover (usa 'us' para Estados Unidos, 'eu' para Europa)
CLOVER_REGION=us

# Nombre del restaurante/negocio (aparece en el menú)
RESTAURANT_NAME=CAFEARTE

# Carpeta donde se guarda el menú generado
OUTPUT_DIR=./output
